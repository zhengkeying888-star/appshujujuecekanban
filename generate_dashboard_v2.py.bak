# Screen 2: Conversion Funnel
# Prepare funnel data
fj = user_journey
march_funnel = [
    {'value': fj['march']['exposure'], 'name': '曝光 UV'},
    {'value': fj['march']['click'], 'name': '点击 UV'},
    {'value': fj['march']['lead'], 'name': '线索数'},
]
april_funnel = [
    {'value': fj['april']['exposure'], 'name': '曝光 UV'},
    {'value': fj['april']['click'], 'name': '点击 UV'},
    {'value': fj['april']['lead'], 'name': '线索数'},
]

# Backend stages data for flow chart
backend_stages = fj['backend_stages']
backend_keys = fj['backend_keys']

s2_html = f"""
<div class="screen" id="screen2">
  <div class="screen-title">2. 转化链路全景</div>
  <div style="display:grid;grid-template-columns:55% 45%;gap:20px;margin-bottom:20px">
    <!-- Left: Funnel + Drill-down -->
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">filter_alt</span>
        转化链路全景
      </div>
      <div id="funnel-chart" style="width:100%;height:280px"></div>
      <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border-subtle)">
        <div style="font-size:13px;color:var(--text-secondary);margin-bottom:12px">下钻链路</div>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px">
"""

# Build flow nodes
for i, (stage, key) in enumerate(zip(backend_stages, backend_keys)):
    m_val = fj['march'][key]
    a_val = fj['april'][key]
    rate_key = key + '_rate' if key != 'friend' else 'friend_rate'
    m_rate = fj['march'].get(rate_key, 0)
    s2_html += f"""
          <div style="flex:1;text-align:center">
            <div style="background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:10px;padding:10px 4px">
              <div style="font-size:14px;font-weight:700;color:var(--accent-primary)">{m_rate:.1f}%</div>
              <div style="font-size:11px;color:var(--text-secondary);margin-top:2px">{stage}</div>
              <div style="font-size:12px;color:var(--text-primary);margin-top:2px">{fmt_int(a_val)}</div>
            </div>
          </div>
"""
    if i < len(backend_stages) - 1:
        s2_html += '<div style="color:var(--text-tertiary)">→</div>'

s2_html += """
        </div>
      </div>
    </div>

    <!-- Right: Stage Comparison -->
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">compare_arrows</span>
        各阶段转化率对比
      </div>
      <div id="stage-compare-chart" style="width:100%;height:380px"></div>
    </div>
  </div>

  <!-- Diagnosis Cards -->
  <div class="grid-3">
"""

# Top 3 worst diagnosis
diagnosis_sorted = sorted(cc, key=lambda x: x['mom'])
for d_item in diagnosis_sorted[:3]:
    status_color = 'var(--danger)' if d_item['mom'] < 0 else 'var(--success)'
    arrow = '↓' if d_item['mom'] < 0 else '↑'
    s2_html += f"""
    <div class="card animate-in" style="border-left:3px solid {status_color}">
      <div class="flex justify-between items-center" style="margin-bottom:8px">
        <span style="font-size:16px;font-weight:700">{d_item['metric']}</span>
        <span class="badge badge-info">{d_item.get('owner','运营')}</span>
      </div>
      <div style="font-size:20px;font-weight:700;margin-bottom:4px">
        {d_item['march']}% <span style="color:var(--text-tertiary)">→</span> {d_item['april']}% <span style="color:{status_color}">{arrow}{abs(d_item['mom']):.1f}pp</span>
      </div>
      <div style="font-size:14px;color:var(--text-secondary)">{d_item.get('issue','')}</div>
    </div>
"""

s2_html += """
  </div>
</div>
"""

# Screen 3: Root Cause Drill-down
# Prepare scatter data for efficiency matrix
scatter_eff = []
for r in rem:
    scatter_eff.append({
        'name': r['resource'],
        'value': [round(r['lead_gen_rate'], 2), round(r['arpu'], 0)],
        'leads': r['leads'],
        'gmv': r['gmv'],
    })

# Prepare growth matrix data
scatter_growth = []
for r in rgm:
    scatter_growth.append({
        'name': r['resource'],
        'value': [round(r['leads_mom'], 1), round(r['order_rate_mom'], 1)],
        'leads': r['leads'],
        'gmv': r['gmv'],
    })

s3_html = """
<div class="screen" id="screen3">
  <div class="screen-title">3. 根因下钻</div>

  <!-- Module 1: Efficiency Matrix -->
  <div class="card animate-in" style="margin-bottom:20px">
    <div class="section-title">
      <span class="material-symbols-outlined">scatter_plot</span>
      资源位效率矩阵
    </div>
    <div id="efficiency-matrix-chart" style="width:100%;height:440px"></div>
  </div>

  <!-- Module 2 & 3: Growth Matrix + Ranking -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">trending_up</span>
        资源位增长矩阵
      </div>
      <div id="growth-matrix-chart" style="width:100%;height:380px"></div>
    </div>
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">sort</span>
        资源位效率 TOP10
      </div>
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>排名</th>
              <th>资源位</th>
              <th>线索数</th>
              <th>线索生成率</th>
              <th>首单转化率</th>
              <th>GMV</th>
            </tr>
          </thead>
          <tbody>
"""

# Sort by leads desc, take top 10
re_top = sorted(re, key=lambda x: x['leads'], reverse=True)[:10]
for idx, r in enumerate(re_top, 1):
    row_class = 'growth' if r['leads_mom'] > 0 else 'decline'
    arrow = '↑' if r['leads_mom'] > 0 else '↓'
    color = 'text-success' if r['leads_mom'] > 0 else 'text-danger'
    s3_html += f"""
            <tr class="{row_class}">
              <td style="font-weight:700;color:var(--text-tertiary)">#{idx}</td>
              <td>{r['resource']}</td>
              <td>{fmt_int(r['leads'])}</td>
              <td>{fmt_pct(r['lead_gen_rate'])}</td>
              <td>{fmt_pct(r['order_rate'])}</td>
              <td>{fmt_money(r['gmv'])} <span class="{color}">{arrow}{abs(r['leads_mom']):.0f}%</span></td>
            </tr>
"""

s3_html += """
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Module 4,5,6: Price Band + Sunburst + MAU -->
  <div class="grid-3">
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">donut_large</span>
        价格带结构
      </div>
      <div id="price-band-chart" style="width:100%;height:280px"></div>
    </div>
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">brightness_7</span>
        价格带 × 品类类型
      </div>
      <div id="sunburst-chart" style="width:100%;height:280px"></div>
    </div>
    <div class="card animate-in">
      <div class="section-title">
        <span class="material-symbols-outlined">group</span>
        月活用户等级
      </div>
      <div id="mau-chart" style="width:100%;height:280px"></div>
    </div>
  </div>
</div>
"""

# Screen 4: Strategy
s4_html = """
<div class="screen" id="screen4">
  <div class="screen-title">4. 策略建议</div>

  <!-- Strategy Cards -->
  <div class="grid-3" style="margin-bottom:20px">
"""

for sc in strategy_cards:
    cat_class = {'产研': 'product', '运营': 'ops', '内容': 'content'}.get(sc['category'], 'product')
    s4_html += f"""
    <div class="card strategy-card animate-in">
      <div>
        <span class="cat-tag {cat_class}">{sc['category']}</span>
      </div>
      <div class="st-title">{sc['title']}</div>
      <div class="st-desc">{sc['desc']}</div>
      <div class="st-footer">
        <span class="text-success">预计 GMV 影响: {sc['gmv_impact']}</span>
        <span class="text-warning">风险: {sc['risk']}</span>
      </div>
      <div class="dots">
"""
    for i in range(5):
        filled = 'filled' if i < sc['difficulty'] else ''
        s4_html += f'<div class="dot {filled}"></div>'
    s4_html += """
      </div>
    </div>
"""

s4_html += """
  </div>

  <!-- Resource Allocation -->
  <div class="card animate-in" style="margin-bottom:20px">
    <div class="section-title">
      <span class="material-symbols-outlined">table_chart</span>
      资源位投放调整建议
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>资源位</th>
            <th>当前占比</th>
            <th>建议占比</th>
            <th>预期 ROI</th>
            <th>置信度</th>
          </tr>
        </thead>
        <tbody>
"""

for ra in resource_allocation:
    roi_color = 'text-success' if ra['roi'].startswith('+') else 'text-danger'
    highlight = 'style="background:rgba(59,130,246,0.1)"' if ra['current_pct'] != ra['suggested_pct'] else ''
    stars = '★' * ra['confidence'] + '☆' * (5 - ra['confidence'])
    s4_html += f"""
          <tr>
            <td>{ra['resource']}</td>
            <td>{ra['current_pct']}%</td>
            <td {highlight}>{ra['suggested_pct']}%</td>
            <td class="{roi_color}">{ra['roi']}</td>
            <td style="color:var(--accent-primary)">{stars}</td>
          </tr>
"""

s4_html += """
        </tbody>
      </table>
    </div>
  </div>

  <!-- Action Checklist -->
  <div class="card animate-in">
    <div class="section-title">
      <span class="material-symbols-outlined">checklist</span>
      次月核心行动清单
    </div>
    <div>
"""

for ac in action_checklist:
    p_class = 'p0' if ac['priority'] == 'P0' else ''
    s4_html += f"""
      <div class="checklist-item {p_class}">
        <div class="checklist-num">{ac['seq']}</div>
        <div class="checklist-content">
          <div class="checklist-title">{ac['title']}</div>
          <div class="checklist-meta">
            <span class="badge badge-info">{ac['owner']}</span>
            <span>截止日期: {ac['deadline']}</span>
            <span class="badge {'badge-danger' if ac['priority']=='P0' else 'badge-warning'}">{ac['priority']}</span>
          </div>
        </div>
      </div>
"""

s4_html += """
    </div>
  </div>
</div>
"""

# Footer
footer_html = """
<div class="footer">
  APP 商业化决策看板 · 2026年3-4月
</div>
"""

# JS: ECharts initialization and month switching
js_data = f"""
<script>
const RAW_DATA = {json.dumps(data, ensure_ascii=False)};
let currentMonth = 'march';

function setMonth(m) {{
  currentMonth = m;
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  renderCharts();
}}

function renderCharts() {{
  // 1. Conversion Change Chart
  const ccChart = echarts.init(document.getElementById('conversion-change-chart'));
  const ccData = RAW_DATA.conversion_change.sort((a,b) => Math.abs(b.mom) - Math.abs(a.mom));
  const ccOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      trigger: 'axis',
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}},
      axisPointer: {{type: 'shadow'}},
      formatter: function(p) {{
        const d = ccData[p[0].dataIndex];
        return `<div style="font-weight:600;margin-bottom:4px">${{d.metric}}</div>
                <div>3月: ${{d.march}}%</div>
                <div>4月: ${{d.april}}%</div>
                <div>环比: ${{d.mom > 0 ? '+' : ''}}${{d.mom.toFixed(1)}}pp</div>`;
      }}
    }},
    grid: {{left: 100, right: 60, top: 20, bottom: 30}},
    xAxis: {{
      type: 'value', max: 100,
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8', formatter: '{value}%'}}
    }},
    yAxis: {{
      type: 'category',
      data: ccData.map(d => d.metric),
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      axisLabel: {{color: '#f8fafc', fontSize: 13}}
    }},
    series: [
      {{
        name: '3月',
        type: 'bar',
        data: ccData.map(d => d.march),
        itemStyle: {{color: 'rgba(59,130,246,0.5)', borderRadius: [4,0,0,4]}},
        barHeight: 16,
        barGap: '20%'
      }},
      {{
        name: '4月',
        type: 'bar',
        data: ccData.map(d => d.april),
        itemStyle: {{color: '#3b82f6', borderRadius: [0,4,4,0]}},
        barHeight: 16
      }}
    ]
  }};
  ccChart.setOption(ccOption);

  // 2. Funnel Chart
  const funnelChart = echarts.init(document.getElementById('funnel-chart'));
  const isMarch = currentMonth === 'march';
  const funnelData = isMarch ? {json.dumps(march_funnel, ensure_ascii=False)} : {json.dumps(april_funnel, ensure_ascii=False)};
  const funnelOption = {{
    backgroundColor: 'transparent',
    color: ['#1e3a5f', '#312e5a', '#1e3a3a'],
    series: [{{
      type: 'funnel',
      left: '10%', width: '80%',
      minSize: '20%', maxSize: '100%',
      sort: 'descending',
      gap: 2,
      label: {{
        show: true,
        position: 'inside',
        color: '#fff',
        fontSize: 13,
        formatter: function(p) {{
          const rates = isMarch ? [2.1, 6.7, 69.8] : [1.27, 5.8, 69.7];
          const rate = rates[p.dataIndex] || 0;
          return p.name + '\\n' + p.value.toLocaleString() + '\\n' + rate + '%';
        }}
      }},
      itemStyle: {{
        borderColor: 'transparent',
        color: function(p) {{
          const colors = [
            new echarts.graphic.LinearGradient(0,0,0,1,[{{offset:0,color:'#1e3a5f'}},{{offset:1,color:'#3b82f6'}}]),
            new echarts.graphic.LinearGradient(0,0,0,1,[{{offset:0,color:'#312e5a'}},{{offset:1,color:'#8b5cf6'}}]),
            new echarts.graphic.LinearGradient(0,0,0,1,[{{offset:0,color:'#1e3a3a'}},{{offset:1,color:'#10b981'}}])
          ];
          return colors[p.dataIndex];
        }}
      }},
      data: funnelData
    }}]
  }};
  funnelChart.setOption(funnelOption);

  // 3. Stage Compare Chart
  const scChart = echarts.init(document.getElementById('stage-compare-chart'));
  const stages = ['CTR', '领课转化率', '好友率', '到课率', '完课率', '首单转化率'];
  const marchRates = [2.1, 6.7, 69.78, 97.12, 75.61, 14.93];
  const aprilRates = [1.27, 5.8, 69.74, 89.12, 76.15, 14.91];
  const scOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      trigger: 'axis',
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}}
    }},
    legend: {{
      data: ['3月', '4月'],
      bottom: 0,
      textStyle: {{color: '#94a3b8'}}
    }},
    grid: {{left: 80, right: 20, top: 20, bottom: 40}},
    xAxis: {{
      type: 'value',
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8', formatter: '{value}%'}}
    }},
    yAxis: {{
      type: 'category',
      data: stages,
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      axisLabel: {{color: '#f8fafc', fontSize: 13}}
    }},
    series: [
      {{
        name: '3月',
        type: 'bar',
        data: marchRates,
        itemStyle: {{color: 'rgba(59,130,246,0.5)', borderRadius: [4,0,0,4]}},
        barHeight: 14
      }},
      {{
        name: '4月',
        type: 'bar',
        data: aprilRates,
        itemStyle: {{color: '#3b82f6', borderRadius: [0,4,4,0]}},
        barHeight: 14
      }}
    ]
  }};
  scChart.setOption(scOption);

  // 4. Efficiency Matrix
  const emChart = echarts.init(document.getElementById('efficiency-matrix-chart'));
  const emData = RAW_DATA.resource_efficiency_matrix.map(r => ({{
    name: r.resource,
    value: [parseFloat(r.lead_gen_rate.toFixed(2)), parseFloat(r.arpu.toFixed(0))],
    leads: r.leads,
    gmv: r.gmv
  }}));
  const xVals = emData.map(d => d.value[0]);
  const yVals = emData.map(d => d.value[1]);
  const xMedian = xVals.sort((a,b)=>a-b)[Math.floor(xVals.length/2)];
  const yMedian = yVals.sort((a,b)=>a-b)[Math.floor(yVals.length/2)];
  const emOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}},
      formatter: function(p) {{
        return `<div style="font-weight:600">${{p.name}}</div>
                <div>线索数: ${{p.data.leads?.toLocaleString()}}</div>
                <div>GMV: ¥${{(p.data.gmv/10000).toFixed(1)}}万</div>
                <div>线索生成率: ${{p.value[0]}}%</div>
                <div>单线索产出: ¥${{p.value[1]}}</div>`;
      }}
    }},
    grid: {{left: 60, right: 60, top: 40, bottom: 40}},
    xAxis: {{
      type: 'value', name: '线索生成率(%)',
      nameTextStyle: {{color: '#94a3b8'}},
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8'}}
    }},
    yAxis: {{
      type: 'value', name: '单线索产出(元)',
      nameTextStyle: {{color: '#94a3b8'}},
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8'}}
    }},
    series: [{{
      type: 'scatter',
      data: emData,
      symbolSize: function(p, params) {{
        const gmv = params.data.gmv || 0;
        return Math.max(12, Math.min(40, gmv / 30000));
      }},
      itemStyle: {{
        color: function(p) {{
          const x = p.value[0], y = p.value[1];
          if (x >= xMedian && y >= yMedian) return '#10b981';
          if (x >= xMedian && y < yMedian) return '#f59e0b';
          if (x < xMedian && y >= yMedian) return '#3b82f6';
          return '#64748b';
        }},
        borderColor: '#fff',
        borderWidth: 1
      }},
      label: {{
        show: true,
        position: 'top',
        color: '#94a3b8',
        fontSize: 11,
        formatter: '{{b}}'
      }},
      markArea: {{
        silent: true,
        data: [
          [{{
            name: '明星资源位',
            xAxis: xMedian,
            yAxis: yMedian,
            itemStyle: {{color: 'rgba(16,185,129,0.06)'}},
            label: {{position: 'insideTopRight', color: '#10b981', fontSize: 14, fontWeight: 'bold'}}
          }}, {{xAxis: 'max', yAxis: 'max'}}],
          [{{
            name: '流量粗放',
            xAxis: xMedian,
            yAxis: 'min',
            itemStyle: {{color: 'rgba(245,158,11,0.06)'}},
            label: {{position: 'insideBottomRight', color: '#f59e0b', fontSize: 14, fontWeight: 'bold'}}
          }}, {{xAxis: 'max', yAxis: yMedian}}],
          [{{
            name: '精准入口',
            xAxis: 'min',
            yAxis: yMedian,
            itemStyle: {{color: 'rgba(59,130,246,0.06)'}},
            label: {{position: 'insideTopLeft', color: '#3b82f6', fontSize: 14, fontWeight: 'bold'}}
          }}, {{xAxis: xMedian, yAxis: 'max'}}],
          [{{
            name: '观察淘汰',
            xAxis: 'min',
            yAxis: 'min',
            itemStyle: {{color: 'rgba(148,163,184,0.06)'}},
            label: {{position: 'insideBottomLeft', color: '#64748b', fontSize: 14, fontWeight: 'bold'}}
          }}, {{xAxis: xMedian, yAxis: yMedian}}]
        ]
      }},
      markLine: {{
        silent: true,
        lineStyle: {{color: 'rgba(148,163,184,0.3)', type: 'dashed'}},
        data: [
          {{xAxis: xMedian}},
          {{yAxis: yMedian}}
        ]
      }}
    }}]
  }};
  emChart.setOption(emOption);

  // 5. Growth Matrix
  const gmChart = echarts.init(document.getElementById('growth-matrix-chart'));
  const gmData = RAW_DATA.resource_growth_matrix.map(r => ({{
    name: r.resource,
    value: [parseFloat(r.leads_mom.toFixed(1)), parseFloat(r.order_rate_mom.toFixed(1))],
    gmv: r.gmv
  }}));
  const gmOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}},
      formatter: function(p) {{
        return `<div style="font-weight:600">${{p.name}}</div>
                <div>线索环比: ${{p.value[0]}}%</div>
                <div>首单转化率环比: ${{p.value[1]}}pp</div>
                <div>4月GMV: ¥${{(p.data.gmv/10000).toFixed(1)}}万</div>`;
      }}
    }},
    grid: {{left: 60, right: 40, top: 40, bottom: 40}},
    xAxis: {{
      type: 'value', name: '线索数环比(%)',
      nameTextStyle: {{color: '#94a3b8'}},
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8'}}
    }},
    yAxis: {{
      type: 'value', name: '首单转化率环比(pp)',
      nameTextStyle: {{color: '#94a3b8'}},
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8'}}
    }},
    series: [{{
      type: 'scatter',
      data: gmData,
      symbolSize: function(p, params) {{
        const gmv = params.data.gmv || 0;
        return Math.max(10, Math.min(35, gmv / 35000));
      }},
      itemStyle: {{
        color: function(p) {{
          const x = p.value[0], y = p.value[1];
          if (x >= 0 && y >= 0) return '#10b981';
          if (x < 0 && y >= 0) return '#3b82f6';
          if (x >= 0 && y < 0) return '#f59e0b';
          return '#ef4444';
        }},
        borderColor: '#fff',
        borderWidth: 1
      }},
      label: {{show: true, position: 'top', color: '#94a3b8', fontSize: 10, formatter: '{{b}}'}},
      markLine: {{
        silent: true,
        lineStyle: {{color: 'rgba(148,163,184,0.3)', type: 'dashed'}},
        data: [{{xAxis: 0}}, {{yAxis: 0}}]
      }}
    }}]
  }};
  gmChart.setOption(gmOption);

  // 6. Price Band Donut
  const pbChart = echarts.init(document.getElementById('price-band-chart'));
  const pbData = RAW_DATA.price_band_distribution;
  const pbColors = ['#3b82f6', '#8b5cf6', '#06b6d4', '#64748b'];
  const marchPb = pbData.filter(d => d.month === '2026-03');
  const aprilPb = pbData.filter(d => d.month === '2026-04');
  const pbOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}},
      formatter: '{{b}}: {{c}} ({{d}}%)'
    }},
    legend: {{
      bottom: 0,
      textStyle: {{color: '#94a3b8', fontSize: 11}},
      itemWidth: 10, itemHeight: 10
    }},
    series: [
      {{
        name: '3月',
        type: 'pie',
        radius: ['45%', '65%'],
        center: ['30%', '45%'],
        label: {{show: true, color: '#94a3b8', fontSize: 11, formatter: '{{b}} {{d}}%'}},
        labelLine: {{lineStyle: {{color: 'rgba(148,163,184,0.3)'}}}},
        data: marchPb.map((d,i) => ({{value: d.leads, name: d.price_band, itemStyle: {{color: pbColors[i % pbColors.length]}}}}))
      }},
      {{
        name: '4月',
        type: 'pie',
        radius: ['45%', '65%'],
        center: ['70%', '45%'],
        label: {{show: true, color: '#94a3b8', fontSize: 11, formatter: '{{b}} {{d}}%'}},
        labelLine: {{lineStyle: {{color: 'rgba(148,163,184,0.3)'}}}},
        data: aprilPb.map((d,i) => ({{value: d.leads, name: d.price_band, itemStyle: {{color: pbColors[i % pbColors.length]}}}}))
      }}
    ]
  }};
  pbChart.setOption(pbOption);

  // 7. Sunburst (simplified)
  const sbChart = echarts.init(document.getElementById('sunburst-chart'));
  const sbOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}}
    }},
    series: [{{
      type: 'sunburst',
      radius: ['20%', '70%'],
      data: [
        {{
          name: '0元课',
          itemStyle: {{color: '#3b82f6'}},
          children: [{{name: '正式品', value: 8000, itemStyle: {{color: '#3b82f6'}}}}, {{name: '孵化品', value: 2000, itemStyle: {{color: '#10b981'}}}}]
        }},
        {{
          name: '1.1元课',
          itemStyle: {{color: '#8b5cf6'}},
          children: [{{name: '正式品', value: 3000, itemStyle: {{color: '#8b5cf6'}}}}, {{name: '孵化品', value: 1000, itemStyle: {{color: '#10b981'}}}}]
        }},
        {{
          name: '3.9元课',
          itemStyle: {{color: '#06b6d4'}},
          children: [{{name: '正式品', value: 2000, itemStyle: {{color: '#06b6d4'}}}}, {{name: '孵化品', value: 500, itemStyle: {{color: '#10b981'}}}}]
        }},
        {{
          name: '其他',
          itemStyle: {{color: '#64748b'}},
          children: [{{name: '正式品', value: 1500, itemStyle: {{color: '#64748b'}}}}, {{name: '孵化品', value: 300, itemStyle: {{color: '#10b981'}}}}]
        }}
      ],
      label: {{color: '#f8fafc', fontSize: 11}},
      itemStyle: {{borderColor: '#1e293b', borderWidth: 2}}
    }}]
  }};
  sbChart.setOption(sbOption);

  // 8. MAU Stacked Bar
  const mauChart = echarts.init(document.getElementById('mau-chart'));
  const mauLevels = RAW_DATA.mau_by_level['2026-04'] ? Object.keys(RAW_DATA.mau_by_level['2026-04']) : ['新用户','活跃用户','忠诚用户','沉睡用户'];
  const mauMarch = mauLevels.map(l => RAW_DATA.mau_by_level['2026-03']?.[l] || 0);
  const mauApril = mauLevels.map(l => RAW_DATA.mau_by_level['2026-04']?.[l] || 0);
  const mauColors = ['#3b82f6', '#8b5cf6', '#10b981', '#f59e0b'];
  const mauOption = {{
    backgroundColor: 'transparent',
    tooltip: {{
      trigger: 'axis',
      backgroundColor: '#334155',
      borderColor: 'rgba(148,163,184,0.2)',
      textStyle: {{color: '#f8fafc'}},
      axisPointer: {{type: 'shadow'}}
    }},
    legend: {{
      right: 0,
      orient: 'vertical',
      textStyle: {{color: '#94a3b8', fontSize: 11}},
      itemWidth: 10, itemHeight: 10
    }},
    grid: {{left: 60, right: 100, top: 10, bottom: 20}},
    xAxis: {{
      type: 'value',
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      splitLine: {{lineStyle: {{color: 'rgba(148,163,184,0.1)', type: 'dashed'}}}},
      axisLabel: {{color: '#94a3b8', formatter: v => (v/10000).toFixed(0)+'万'}}
    }},
    yAxis: {{
      type: 'category',
      data: ['3月', '4月'],
      axisLine: {{lineStyle: {{color: 'rgba(148,163,184,0.2)'}}}},
      axisLabel: {{color: '#f8fafc', fontSize: 13}}
    }},
    series: mauLevels.map((l, i) => ({{
      name: l,
      type: 'bar',
      stack: 'total',
      data: [mauMarch[i] || 0, mauApril[i] || 0],
      itemStyle: {{color: mauColors[i % mauColors.length]}},
      label: {{show: true, position: 'inside', color: '#fff', fontSize: 11, formatter: p => p.value > 5000 ? ((p.value/RAW_DATA.mau_summary['2026-03'+(p.dataIndex?'-04':'-03')])*100).toFixed(0)+'%' : ''}}
    }}))
  }};
  mauChart.setOption(mauOption);
}}

// Export
function exportReport() {{
  const btn = event.target;
  btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px">hourglass_top</span>生成中...';
  setTimeout(() => {{
    const blob = new Blob([document.documentElement.outerHTML], {{type: 'text/html'}});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'APP商业化决策看板_2026年3-4月.html';
    a.click();
    URL.revokeObjectURL(url);
    btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px">download</span>导出 HTML 月报';
  }}, 500);
}}

// Stagger animation
window.addEventListener('load', () => {{
  renderCharts();
  document.querySelectorAll('.animate-in').forEach((el, i) => {{
    el.style.animationDelay = (i * 80) + 'ms';
  }});
}});

window.addEventListener('resize', () => {{
  ['conversion-change-chart','funnel-chart','stage-compare-chart','efficiency-matrix-chart','growth-matrix-chart','price-band-chart','sunburst-chart','mau-chart'].forEach(id => {{
    const chart = echarts.getInstanceByDom(document.getElementById(id));
    if (chart) chart.resize();
  }});
}});
</script>
</body>
</html>
"""

# Assemble full HTML
full_html = f"""<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APP 商业化决策看板 v2</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0">
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
<style>
{CSS_VARS}
{COMMON_CSS}
.navbar{{position:fixed;top:0;left:0;right:0;height:64px;background:var(--bg-surface);border-bottom:1px solid var(--border-subtle);backdrop-filter:blur(12px);z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:0 32px}}
.nav-left{{display:flex;align-items:center;gap:12px}}
.nav-logo{{font-size:20px;font-weight:700;background:var(--accent-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent}}
.nav-sub{{font-size:13px;color:var(--text-tertiary);background:var(--bg-elevated);padding:2px 8px;border-radius:6px}}
.nav-tabs{{display:flex;gap:4px;background:var(--bg-elevated);padding:4px;border-radius:8px}}
.nav-tab{{padding:6px 16px;border-radius:8px;font-size:14px;font-weight:500;color:var(--text-secondary);cursor:pointer;border:none;background:transparent;transition:all .2s}}
.nav-tab.active{{background:var(--accent-gradient);color:#fff}}
.main-content{{padding:88px 32px 32px;max-width:1440px;margin:0 auto}}
.screen{{margin-bottom:40px}}
.screen-title{{font-size:24px;font-weight:700;margin-bottom:20px;color:var(--text-primary)}}
.hero-card{{position:relative;overflow:hidden}}
.hero-card::before{{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:var(--accent-primary);border-radius:16px 0 0 16px}}
.hero-label{{font-size:11px;font-weight:600;color:var(--accent-primary);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px}}
.hero-title{{font-size:32px;font-weight:700;color:var(--text-primary);margin-bottom:8px}}
.hero-sub{{font-size:16px;color:var(--text-secondary);margin-bottom:16px}}
.progress-bar{{display:flex;height:6px;border-radius:3px;overflow:hidden;background:var(--bg-elevated)}}
.progress-bar .red{{background:var(--danger);height:100%}}
.progress-bar .green{{background:var(--success);height:100%}}
.progress-labels{{display:flex;justify-content:space-between;margin-top:6px;font-size:12px;color:var(--text-tertiary)}}
.signal-card{{position:relative;padding:20px}}
.signal-card .left-border{{position:absolute;left:0;top:16px;bottom:16px;width:3px;border-radius:0 3px 3px 0}}
.signal-card .metric-name{{font-size:13px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}}
.signal-card .metric-value{{font-size:40px;font-weight:700;color:var(--text-primary);font-variant-numeric:tabular-nums;letter-spacing:-.02em}}
.signal-card .metric-change{{font-size:13px;color:var(--text-tertiary);margin-top:4px}}
.data-table{{width:100%;border-collapse:separate;border-spacing:0}}
.data-table th{{background:var(--bg-elevated);color:var(--text-tertiary);font-size:12px;font-weight:600;text-transform:uppercase;padding:12px 16px;text-align:left}}
.data-table td{{padding:14px 16px;border-bottom:1px solid var(--border-subtle);font-size:14px;color:var(--text-primary)}}
.data-table tr:hover td{{background:var(--bg-elevated)}}
.data-table tr.growth td{{background:rgba(16,185,129,0.06)}}
.data-table tr.decline td{{background:rgba(239,68,68,0.06)}}
.action-card{{border-left:3px solid transparent}}
.action-card.product{{border-left-color:var(--accent-primary)}}
.action-card.ops{{border-left-color:var(--success)}}
.action-card.content{{border-left-color:var(--warning)}}
.strategy-card{{display:flex;flex-direction:column;gap:12px}}
.strategy-card .cat-tag{{display:inline-block;padding:4px 10px;border-radius:4px;font-size:12px;font-weight:600}}
.strategy-card .cat-tag.product{{background:rgba(59,130,246,0.15);color:var(--accent-primary)}}
.strategy-card .cat-tag.ops{{background:rgba(16,185,129,0.15);color:var(--success)}}
.strategy-card .cat-tag.content{{background:rgba(245,158,11,0.15);color:var(--warning)}}
.strategy-card .st-title{{font-size:18px;font-weight:700}}
.strategy-card .st-desc{{font-size:14px;color:var(--text-secondary);line-height:1.6}}
.strategy-card .st-footer{{display:flex;justify-content:space-between;align-items:center;font-size:13px;margin-top:auto;padding-top:12px;border-top:1px solid var(--border-subtle)}}
.dots{{display:flex;gap:4px}}
.dot{{width:8px;height:8px;border-radius:50%;background:var(--border-subtle)}}
.dot.filled{{background:var(--accent-primary)}}
.checklist-item{{display:flex;align-items:center;gap:16px;padding:16px 0;border-bottom:1px solid var(--border-subtle)}}
.checklist-item:last-child{{border-bottom:none}}
.checklist-item.p0{{border-left:3px solid var(--danger);padding-left:16px;margin-left:-3px}}
.checklist-num{{width:32px;height:32px;border-radius:50%;background:var(--accent-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0}}
.checklist-content{{flex:1}}
.checklist-title{{font-size:16px;font-weight:600}}
.checklist-meta{{display:flex;gap:12px;margin-top:4px;font-size:13px;color:var(--text-secondary)}}
.footer{{text-align:center;padding:40px 0;font-size:13px;color:var(--text-tertiary);border-top:1px solid var(--border-subtle);margin-top:40px}}
@keyframes fadeInUp{{from{{opacity:0;transform:translateY(16px)}}to{{opacity:1;transform:translateY(0)}}}}
.animate-in{{animation:fadeInUp .6s cubic-bezier(.16,1,.3,1) forwards;opacity:0}}
</style>
</head>
<body>
{nav_html}
<div class="main-content">
{s1_html}
{s2_html}
{s3_html}
{s4_html}
{footer_html}
</div>
{js_data}
"""

# Write output
os.makedirs(os.path.dirname(OUTPUT_PATH), exist_ok=True)
with open(OUTPUT_PATH, 'w', encoding='utf-8') as f:
    f.write(full_html)

print(f"Done! Written to {OUTPUT_PATH}")
print(f"File size: {len(full_html):,} bytes")
